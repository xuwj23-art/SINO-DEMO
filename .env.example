# ============================================================
# Knowledge Base Management System - Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env or real secrets to the repository.
# API keys must stay in backend environment only, never in frontend.

# --- Application ---
APP_ENV=development
APP_NAME=knowledge-base-rag
APP_DEBUG=true

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8000

# --- Demo scope: local filesystem + in-memory vectors ---
DATA_DIR=./data
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# --- Demo model settings ---
# Demo data must be public/synthetic/desensitized only.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=  # optional: your model gateway URL, e.g. https://your-gateway.example.com
GEN_MODEL=claude-opus-4-8
EMBED_MODEL=BAAI/bge-m3
REGULATORY_TEST_SITE_URL=http://localhost:3001

# --- Search Gateway (MVP: disabled by default) ---
SEARCH_GATEWAY_ENABLED=false
SEARCH_ALLOWLIST=

# --- Audit Logging ---
AUDIT_LOG_LEVEL=standard
# Log retention period should be approved by Compliance / IT Security
AUDIT_RETENTION_DAYS=90

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changeme-generate-a-real-secret-key
