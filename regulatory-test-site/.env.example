# Optional: Upstash Redis (REST) for persistent storage on Vercel.
# Leave unset to use in-memory fallback (fine for local `next dev`).
# Create a free DB at https://console.upstash.com and copy the REST creds,
# or add the "Upstash" integration from the Vercel Marketplace.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
